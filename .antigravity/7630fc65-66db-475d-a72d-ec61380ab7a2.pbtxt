          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  return hueMatch && satMatch && valMatch;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
