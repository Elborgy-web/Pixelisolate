    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import express from \"express\";\nimport path from \"path\";\nimport dotenv from \"dotenv\";\nimport { GoogleGenAI, Type } from \"@google/genai\";\nimport { createServer as createViteServer } from \"vite\";\n\ndotenv.config();\n\nconst app = express();\nconst PORT = 3000;\n\n// Set up json parser with extended limit to support large image transfers\napp.use(express.json({ limit: \"20mb\" }));\n\n// Lazy initialisation of GoogleGenAI client to avoid crash on startup if key is missing\nlet aiClient: GoogleGenAI | null = null;\n\nfunction getAiClient(): GoogleGenAI {\n  if (!aiClient) {\n    const key = process.env.GEMINI_API_KEY;\n    if (!key) {\n      throw new Error(\"GEMINI_API_KEY environment variable is not configured. Please define it in your AI Studio Secrets panel.\");\n    }\n    aiClient = new GoogleGenAI({\n      apiKey: key,\n      httpOptions: {\n        headers: {\n          \"User-Agent\": \"aistudio-build\",\n        },\n      },\n    });\n  }\n  return aiClient;\n}\n\n// REST API for Subject Identity & Analysis (Step 1)\napp.post(\"/api/analyze\", async (req, res) => {\n  try {\n    const { imageBase64, mimeType } = req.body;\n    if (!imageBase64) {\n      res.status(400).json({ error: \"No image content provided.\" });\n      return;\n    }\n\n    const ai = getAiClient();\n    const prompt = `\n      Analyze this user-uploaded image for background removal and subject isolation.\n      Provide a highly precise structural report detailing:\n      1. What or who the primary foreground subject(s) are (subjectName).\n      2. The complexity of the subject outline or boundaries (low, medium, or high), such as presence of hair, fur, transparent textures.\n      3. Colors present on the edges of the subject and background, and if they represent keying difficulties like color bleed-through (colorAnalysis).\n      4. Explicit warning on any parts of the image that might present isolation difficulty (edgeDifficulty).\n      5. Approximate bounding box coordinates of the primary subject as a fraction of image width and height: { x, y, w, h } from 0 to 100.\n      6. Best strategic advice on threshold tolerance, smoothing, and erosion parameters needed for a clean chroma-key mask extraction (segmentationAdvice).\n    `;\n\n    const cleanBase64 = imageBase64.replace(/^data:image\\/[a-z]+;base64,/, \"\");\n\n    const response = await ai.models.generateContent({\n      model: \"gemini-3.5-flash\",\n      contents: [\n        {\n          inlineData: {\n            data: cleanBase64,\n            mimeType: mimeType || \"image/png\",\n          },\n        },\n        { text: prompt },\n      ],\n      config: {\n        responseMimeType: \"application/json\",\n        responseSchema: {\n          type: Type.OBJECT,\n          properties: {\n            subjectName: { type: Type.STRING, description: \"Name of the main foreground subject\" },\n            outlineComplexity: { type: Type.STRING, enum: [\"low\", \"medium\", \"high\"], description: \"Visual edge complexity\" },\n            colorAnalysis: { type: Type.STRING, description: \"Color bleed/clash analysis between background and subject\" },\n            edgeDifficulty: { type: Type.STRING, description: \"Hair, fur, glass transparency, or high frequency edge details found\" },\n            boundingBox: {\n              type: Type.OBJECT,\n              properties: {\n                x: { type: Type.INTEGER, description: \"X percentage coordinate (0-100)\" },\n                y: { type: Type.INTEGER, description: \"Y percentage coordinate (0-100)\" },\n                w: { type: Type.INTEGER, description: \"Width percentage (0-100)\" },\n                h: { type: Type.INTEGER, description: \"Height percentage (0-100)\" },\n              },\n              required: [\"x\", \"y\", \"w\", \"h\"],\n            },\n            segmentationAdvice: { type: Type.STRING, description: \"Recommended chroma key thresholds, dilations, and erosion advice\" },\n          },\n          required: [\"subjectName\", \"outlineComplexity\", \"colorAnalysis\", \"edgeDifficulty\", \"boundingBox\", \"segmentationAdvice\"],\n        },\n      },\n    });\n\n    const reportText = response.text;\n    if (!reportText) {\n      throw new Error(\"No response text returned from Gemini.\");\n    }\n\n    res.json(JSON.parse(reportText.trim()));\n  } catch (err: any) {\n    console.error(\"Gemini Analysis error:\", err);\n    res.status(500).json({ error: err.message || \"Failed to process image analysis using GenAI API.\" });\n  }\n});\n\n// REST API for Gemini AI Chroma Key Masking (Step 2 - Paid pipeline fallback)\napp.post(\"/api/ai-green-screen\", async (req, res) => {\n  try {\n    const { imageBase64, mimeType } = req.body;\n    if (!imageBase64) {\n      res.status(400).json({ error: \"No image content provided.\" });\n      return;\n    }\n\n    const ai = getAiClient();\n    const cleanBase64 = imageBase64.replace(/^data:image\\/[a-z]+;base64,/, \"\");\n\n    const response = await ai.models.generateContent({\n      model: \"gemini-2.5-flash-image\",\n      contents: [\n        {\n          inlineData: {\n            data: cleanBase64,\n            mimeType: mimeType || \"image/png\",\n          },\n        },\n        {\n          text: \"Identify the main foreground subject or subjects in this image. Keep the main foreground subject completely unaltered, preserving its original colors, lighting, textures, and transparency. Replace the entire background area (everything except the main subjects) with a uniform, solid chroma green color. Use the exact hexadecimal value #00FF00 (pure solid RGB 0, 255, 0). The background must be beautifully clean and solid, forming a perfect chroma green screen. Avoid any anti-aliasing artifacts, blurry haloing or color blending at the transition boundaries.\",\n        },\n      ],\n    });\n\n    // Locate the generated image part\n    let imageResponseBase64 = \"\";\n    if (response.candidates?.[0]?.content?.parts) {\n      for (const part of response.candidates[0].content.parts) {\n        if (part.inlineData?.data) {\n          imageResponseBase64 = part.inlineData.data;\n          break;\n        }\n      }\n    }\n\n    if (!imageResponseBase64) {\n      throw new Error(\"The image generation model did not produce an edited image. Make sure your API key has credit/permissions for image model usage.\");\n    }\n\n    res.json({\n      greenScreenImage: `data:image/png;base64,${imageResponseBase64}`,\n    });\n  } catch (err: any) {\n    console.error(\"Gemini Image Editing error:\", err);\n    res.status(500).json({\n      error: err.message || \"Failed to edit image using Gemini Image Editing capabilities. Try the Interactive HSV Chroma keyer instead.\",\n    });\n  }\n});\n\n// Setup dev server with Vite in dev, or serve production build in production\nasync function run() {\n  if (process.env.NODE_ENV !== \"production\") {\n    const vite = await createViteServer({\n      server: { middlewareMode: true },\n      appType: \"spa\",\n    });\n    app.use(vite.middlewares);\n  } else {\n    const distPath = path.join(process.cwd(), \"dist\");\n    app.use(express.static(distPath));\n    app.get(\"*\", (req, res) => {\n      res.sendFile(path.join(distPath, \"index.html\"));\n    });\n  }\n\n  app.listen(PORT, \"0.0.0.0\", () => {\n    console.log(`[Server] Isolator Engine running at http://0.0.0.0:${PORT}`);\n  });\n}\n\nrun().catch((err) => {\n  console.error(\"Server boot failure:\", err);\n});\n"
    }
