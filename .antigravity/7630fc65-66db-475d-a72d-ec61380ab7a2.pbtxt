        lines {
          text: "// Helper to convert RGB to HSV"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "export function rgbToHsv(r: number, g: number, b: number) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  r /= 255;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  g /= 255;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  b /= 255;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const max = Math.max(r, g, b);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const min = Math.min(r, g, b);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const d = max - min;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let h = 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const s = max === 0 ? 0 : d / max;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const v = max;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  if (max !== min) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    switch (max) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      case r:"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        h = (g - b) / d + (g < b ? 6 : 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        break;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      case g:"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        h = (b - r) / d + 2;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        break;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      case b:"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        h = (r - g) / d + 4;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        break;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    h /= 6;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  return {"
