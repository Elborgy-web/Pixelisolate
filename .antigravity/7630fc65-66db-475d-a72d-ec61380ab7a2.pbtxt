        }
        lines {
          text: "  const output = new Uint8Array(alphaGrid.length);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const offset = Math.floor(kernelSize / 2);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  for (let y = 0; y < height; y++) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    for (let x = 0; x < width; x++) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      let minVal = 255;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Scan kernel neighborhood"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      for (let ky = -offset; ky <= offset; ky++) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        for (let kx = -offset; kx <= offset; kx++) {"
