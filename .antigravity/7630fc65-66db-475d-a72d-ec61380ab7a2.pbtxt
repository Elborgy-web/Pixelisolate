        }
        lines {
          text: "      dst[i] = 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      dst[i + 1] = 255;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      dst[i + 2] = 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      dst[i + 3] = 255;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    } else if (distance < threshold) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Replace background with exact pure chroma green screen"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      dst[i] = 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      dst[i + 1] = 255;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      dst[i + 2] = 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      dst[i + 3] = 255;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
