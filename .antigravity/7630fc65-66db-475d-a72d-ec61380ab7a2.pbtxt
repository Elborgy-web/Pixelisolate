      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React from \"react\";\nimport ChromaKeyer from \"./components/ChromaKeyer\";\nimport { Sliders, CheckCircle, HelpCircle, FileCheck, Layers } from \"lucide-react\";\n\nexport default function App() {\n  return (\n    <div id=\"app-container\" className=\"min-h-screen bg-[#0a0b0d] text-gray-100 flex flex-col antialiased selection:bg-emerald-500/30 selection:text-white\">\n      {/* Upper Navigation / Editorial Header */}\n      <header className=\"border-b border-gray-900 bg-gray-950/40 backdrop-blur-md sticky top-0 z-40 px-6 py-4\">\n        <div className=\"max-w-7xl mx-auto flex flex-col md:flex-row gap-4 justify-between items-start md:items-center\">\n          <div>\n            <div className=\"flex items-center gap-2.5\">\n              <div className=\"p-1.5 rounded-lg bg-emerald-500/10 border border-emerald-500/20 text-emerald-400\">\n                <Layers className=\"h-5 w-5\" />\n              </div>\n              <h1 className=\"text-lg font-bold tracking-tight text-white font-sans\">\n                Pixel-Level Image Isolation Engine\n              </h1>\n            </div>\n            <p className=\"text-[11px] text-gray-500 mt-0.5\">\n              High-precision chroma transformation, HSV masking, and morphological edge refinement.\n            </p>\n          </div>\n\n          {/* Workflow Steps Tracker */}\n          <div className=\"flex gap-4 items-center\">\n            <div className=\"flex -space-x-1.5 overflow-hidden font-mono text-[9px] font-semibold text-gray-400\">\n              <div className=\"flex items-center gap-1.5 bg-gray-900 border border-gray-800 px-3 py-1.5 rounded-full shadow-sm\">\n                <span className=\"text-emerald-400\">1</span>\n                <span>Segment Subject</span>\n              </div>\n              <div className=\"flex items-center gap-1.5 bg-gray-900 border border-gray-800 px-3 py-1.5 rounded-full shadow-sm\">\n                <span className=\"text-emerald-400\">2</span>\n                <span>Chroma Green Transform</span>\n              </div>\n              <div className=\"flex items-center gap-1.5 bg-gray-900 border border-gray-800 px-3 py-1.5 rounded-full shadow-sm\">\n                <span className=\"text-emerald-400\">3</span>\n                <span>Python Extract</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </header>\n\n      {/* Main Workspace Frame */}\n      <main className=\"flex-1 max-w-7xl w-full mx-auto p-6 md:p-8\">\n        <ChromaKeyer />\n      </main>\n\n      {/* Footer Details */}\n      <footer className=\"border-t border-gray-900 bg-gray-950/30 py-6 px-6\">\n        <div className=\"max-w-7xl mx-auto flex flex-col sm:flex-row gap-4 justify-between items-center text-[11px] font-mono text-gray-500\">\n          <p>\302\251 2026 Chroma Isolate Engine. Built with React and OpenCV local pipeline emulation.</p>\n          <div className=\"flex gap-4\">\n            <span className=\"hover:text-gray-300 transition cursor-help flex items-center gap-1\">\n              <FileCheck className=\"h-3 w-3\" />\n              Precision Borders (1px)\n            </span>\n          </div>\n        </div>\n      </footer>\n    </div>\n  );\n}\n"
