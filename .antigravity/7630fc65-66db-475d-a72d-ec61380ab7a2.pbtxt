          text: "  v: number,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  hMin: number,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  hMax: number,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  sMin: number,"
