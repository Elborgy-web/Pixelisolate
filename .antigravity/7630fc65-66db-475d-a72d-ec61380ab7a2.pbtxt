        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "/**"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: " * Creates step 2 Chroma-Keyed Image:"
