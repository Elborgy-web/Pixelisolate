        }
        lines {
          text: "): boolean {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Handle circular Hue wrap-around if max is less than min (for red-like hues)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const hueMatch ="
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
